# ---------------------------------------------------------------------------
# Greenco Accounts CRM — server environment
# Copy to `.env` and fill in. Never commit the real .env.
# ---------------------------------------------------------------------------

# HTTP
PORT=4000
# Comma-separated list of allowed CORS origins (the client dev server + prod host)
CORS_ORIGIN=http://localhost:5173,https://accounts.greenco.co.uk

# PostgreSQL
# NOTE: the port is 5432 by default, but if the box already runs another
# Postgres/cluster the installer may pick 5434 etc. Check with `pg_lsclusters`
# and use the PORT shown there. (greenco-web-1 runs on 5434.)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/accounts_crm

# --- Companies House Public Data API -------------------------------------
# Free API key from https://developer.company-information.service.gov.uk/
# Leave blank to disable the integration (the app still works, you just enter
# statutory dates manually).
COMPANIES_HOUSE_API_KEY=
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk

# --- Email reminders via SMTP2GO -----------------------------------------
# Credentials from https://app.smtp2go.com/ (SMTP Users).
# Leave SMTP2GO_API_KEY (or SMTP_USER/SMTP_PASS) blank to disable sending;
# reminders are still computed and shown in the dashboard.
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
REMINDER_FROM="Greenco Accounts <accounts@greenco.co.uk>"
# Where reminder digests are sent (comma-separated)
REMINDER_TO=sam.kahan@greenco.co.uk
# Lets the nightly reminder cron authenticate without a login session:
# POST /api/dashboard/send-reminders?key=<this>. Generate a long random value.
REMINDER_CRON_KEY=

# --- Auth / sessions ------------------------------------------------------
# Secret used to sign session cookies. MUST be a long random string in prod
# (e.g. `openssl rand -hex 32`). Changing it logs everyone out.
SESSION_SECRET=
# Public base URL — used to build password-reset links in emails.
APP_BASE_URL=https://accounts.greenco.co.uk

# --- AI complaints research (Anthropic) ----------------------------------
# Used to research a specific organisation's complaints procedure + deadlines.
# Get a key from https://console.anthropic.com/. Leave blank to disable
# research (complaints still work using the built-in per-type legal defaults).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Inbound complaint email (Microsoft Graph) ----------------------------
# How it works (same catch-all the refurb system already uses):
#   1. Every complaint gets its own unique address, e.g.
#      complaint-71923e@greenco.co.uk (prefix + the ref-code suffix + domain).
#   2. That address is NOT a real mailbox — it falls through to the domain's
#      one catch-all mailbox (where all unaddressed mail already goes, the same
#      mailbox refurb's job-* addresses land in). There is only ONE catch-all
#      per domain; you do not (and cannot) create a second one.
#   3. You CC or BCC the per-complaint address on any email. The app polls the
#      catch-all mailbox and logs ONLY the messages addressed to a complaint
#      (matched by exact recipient, ref code as fallback) — the rest of the
#      mailbox (spam / other mail) is ignored and never stored.
# So point MS_MAILBOX at the EXISTING refurb catch-all mailbox. App-only auth —
# reuse refurb's Azure app; it already has Mail.Read (application).
# Leave blank to disable (a dev inbox is used locally).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# The domain catch-all mailbox (the same one refurb polls).
MS_MAILBOX=refurb@greenco.co.uk

# --- Per-complaint address ------------------------------------------------
# Builds each complaint's unique CC/BCC address as <prefix><code>@<domain>,
# e.g. complaint-71923e@greenco.co.uk. No mail-server config needed — these
# fall through to the existing catch-all above. Keep the prefix distinct from
# refurb's (job-) so the two systems never pick up each other's mail.
COMPLAINT_EMAIL_PREFIX=complaint-
COMPLAINT_EMAIL_DOMAIN=greenco.co.uk
