# ---------------------------------------------------------------------------
# Production environment for docker compose (Hetzner).
# Copy to `.env.production` on the server, fill in, and reference it:
#   docker compose --env-file .env.production up -d --build
# Keep the real file OFF git.
# ---------------------------------------------------------------------------

# Postgres (used by both the db and app containers)
POSTGRES_USER=accounts
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=accounts_crm

# Companies House Public Data API key (free):
#   https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# SMTP2GO (email reminders)
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
REMINDER_FROM="Greenco Accounts <accounts@greenco.co.uk>"
REMINDER_TO=sam.kahan@greenco.co.uk
